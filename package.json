{
  "name": "personal-profile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run content:generate",
    "dev": "next dev",
    "blog:new": "tsx scripts/new-blog-post.ts",
    "content:generate": "tsx scripts/generate-blog-index.ts",
    "content:validate": "tsx scripts/validate-content.ts",
    "prebuild": "npm run content:generate && npm run content:validate",
    "build": "next build && pagefind --site out --output-subdir pagefind",
    "start": "next start",
    "pretypecheck": "npm run content:generate",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.9",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "pagefind": "^1.5.2",
    "tsx": "^4.22.4",
    "typescript": "latest"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
